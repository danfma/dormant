module bench;

# Filtered multi-row read: all products in a category.
query products_by_category(category: String) {
  from Product p
  where p.category == category
  select p
}

# Insert one product (RETURNING the full inserted entity).
mutation create_product(id: Uuid, name: String, category: String, price: Decimal, quantity: Int) {
  insert Product p {
    p.id = id
    p.name = name
    p.category = category
    p.price = price
    p.quantity = quantity
  }
}

# Update a single product's quantity by key (returns affected-row count).
mutation update_product_quantity(id: Uuid, quantity: Int) {
  update Product p
  where p.id == id
  set {
    p.quantity = quantity
  }
}

# Delete a single product by key (returns affected-row count).
mutation delete_product(id: Uuid) {
  delete Product p
  where p.id == id
}
