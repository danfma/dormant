module catalog;

entity Widget {
  id: uuid { constraint primary; }
  name: str;
  quantity: int;
}

entity Author {
  id: uuid { constraint primary; }
  name: str;
}

entity Article {
  id: uuid { constraint primary; }
  title: str;
  writer: Author;
  tags: Set<Tag>;
}

entity Tag {
  id: uuid { constraint primary; }
  label: str;
  article: Article;
}

entity Document {
  id: uuid { constraint primary; }
  data: json;
}
