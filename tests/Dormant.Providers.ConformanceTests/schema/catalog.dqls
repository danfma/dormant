module catalog;

entity Widget {
  id: Uuid { constraint primary; }
  name: String;
  quantity: Int;
}

entity Author {
  id: Uuid { constraint primary; }
  name: String;
}

entity Article {
  id: Uuid { constraint primary; }
  title: String;
  writer: Author;
  tags: Set<Tag>;
}

entity Tag {
  id: Uuid { constraint primary; }
  label: String;
  article: Article;
}

entity Document {
  id: Uuid { constraint primary; }
  data: Json;
}
