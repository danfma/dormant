module catalog;

entity Widget {
  id: Uuid { constraint primary; }
  name: String;
  quantity: Int;
}

entity Author {
  id: Uuid { constraint primary; }
  name: String;
}

entity Article {
  id: Uuid { constraint primary; }
  title: String;
  writer: Author;
  tags: Set<Tag>;
}

entity Tag {
  id: Uuid { constraint primary; }
  label: String;
  article: Article;
}

entity Document {
  id: Uuid { constraint primary; }
  data: Json;
}

# Feature 012: a constrained entity proving the database enforces the generated constraints.
entity Account {
  id: Uuid { constraint primary; }
  email: String {
    constraint unique as accounts_email_key;
    constraint max_length(10);
  }
}
