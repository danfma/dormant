module catalog;

entity Widget {
  id: uuid primary;
  name: str;
  quantity: int;
}

entity Author {
  id: uuid primary;
  name: str;
}

entity Article {
  id: uuid primary;
  title: str;
  writer: Author;
  tags: Set<Tag>;
}

entity Tag {
  id: uuid primary;
  label: str;
  article: Article;
}

entity Document {
  id: uuid primary;
  data: json;
}
