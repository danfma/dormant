module catalog;

# Insert … RETURNING the full inserted entity.
mutation create_widget(id: uuid, name: string, quantity: int) {
  insert Widget w {
    w.id = id
    w.name = name
    w.quantity = quantity
  }
}

# JSON value round-trip (stored as jsonb on PostgreSQL, TEXT on SQLite).
mutation create_document(id: uuid, data: json) {
  insert Document d {
    d.id = id
    d.data = data
  }
}

# with-block (FR-021/FR-022): bind an inserted Author, then insert an Article whose `writer` FK flows from
# the bound author id. Each binding is its own statement in the transaction. Returns the article id.
mutation create_author_with_article(aid: uuid, aname: string, artid: uuid, title: string) {
  with a = (insert Author x {
    x.id = aid
    x.name = aname
  })
  insert Article r {
    r.id = artid
    r.title = title
    r.writer = a
  }
  returning r.id
}

# Static full-entity query.
query widgets_by_name(name: string) {
  from Widget w
  where w.name == name
  select w
}

# Optional parameters (dynamic fragment selection): each filter is included only when supplied; the
# result type is identical for every combination.
query search_widgets(minQuantity: optional int, name: optional string) {
  from Widget w
  where w.quantity >= minQuantity && w.name == name
  order by w.name asc
  select w
}

# Relationship navigation in a predicate (009 P-B): filter Articles by their writer's name. The
# `a.writer.name` path generates a LEFT JOIN from Article to Author on the writer_id FK.
query articles_by_author_name(authorName: string) {
  from Article a
  where a.writer.name == authorName
  select a
}

# Root-object shape (009 US1): fetch an Article with its (to-one) writer, in one query. The nested
# `writer: { … }` generates a JOIN; the result is a nested immutable record (shape = type).
query article_card(id: uuid) {
  from Article a
  where a.id == id
  select a {
    title,
    writer: { name }
  }
}

mutation create_tag(id: uuid, label: string, article: uuid) {
  insert Tag t {
    t.id = id
    t.label = label
    t.article = article
  }
}

# To-many shape (009 US1): fetch an Article with its tags in one query. The nested `tags: { … }`
# (a Set<Tag> collection, backlinked via Tag.article) compiles to a JSON-array correlated subquery;
# the result's Tags is a fully materialized IReadOnlyList.
query article_with_tags(id: uuid) {
  from Article a
  where a.id == id
  select a {
    title,
    tags: { label }
  }
}

# Free composition (009 US2): assemble a new result object from a field plus a navigated value.
query article_feed_item(id: uuid) {
  from Article a
  where a.id == id
  select { headline = a.title, authorName = a.writer.name }
}

# into (009 US3): materialize the composition into a user-owned record (positional, by declaration order).
query article_dto(id: uuid) {
  from Article a
  where a.id == id
  select { headline = a.title, authorName = a.writer.name } into Dormant.Providers.ConformanceTests.ArticleFeedDto
}
