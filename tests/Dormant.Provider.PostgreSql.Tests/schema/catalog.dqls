module catalog;

entity Widget {
  id: uuid { constraint primary; }
  name: str;
  quantity: int;
}

entity Account {
  id: uuid { constraint primary; }
  balance: int;
  version: int { constraint concurrency; }
}

entity StockItem {
  id: uuid { constraint primary; }
  itemName: str;
}

entity Document {
  id: uuid { constraint primary; }
  data: json;
}

entity Author {
  id: uuid { constraint primary; }
  name: str;
}

entity Article {
  id: uuid { constraint primary; }
  title: str;
  writer: Author;
}
