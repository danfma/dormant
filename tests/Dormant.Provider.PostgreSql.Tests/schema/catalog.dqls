module catalog;

entity Widget {
  id: Uuid { constraint primary; }
  name: String;
  quantity: Int;
}

entity Account {
  id: Uuid { constraint primary; }
  balance: Int;
  version: Int { constraint concurrency; }
}

entity StockItem {
  id: Uuid { constraint primary; }
  itemName: String;
}

entity Document {
  id: Uuid { constraint primary; }
  data: Json;
}

entity Author {
  id: Uuid { constraint primary; }
  name: String;
}

entity Article {
  id: Uuid { constraint primary; }
  title: String;
  writer: Author;
}
