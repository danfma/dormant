module catalog;

entity Widget {
  id: uuid primary;
  name: str;
  quantity: int;
}

entity Account {
  id: uuid primary;
  balance: int;
  version: int concurrency;
}

entity StockItem {
  id: uuid primary;
  itemName: str;
}

entity Document {
  id: uuid primary;
  data: json;
}

entity Author {
  id: uuid primary;
  name: str;
}

entity Article {
  id: uuid primary;
  title: str;
  writer: Author;
}
