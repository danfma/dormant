module catalog;

# 002 fork: authored write commands → INSERT … RETURNING, materialize the inserted row.
command CreateWidget(id: uuid, name: str, quantity: int) =
  insert Widget { id := id, name := name, quantity := quantity };

command CreateAccount(id: uuid, balance: int, version: int) =
  insert Account { id := id, balance := balance, version := version };

command CreateStockItem(id: uuid, itemName: str) =
  insert StockItem { id := id, itemName := itemName };

command CreateDocument(id: uuid, data: json) =
  insert Document { id := id, data := data };

# update with optimistic concurrency: matches the expected version; stale → 0 rows affected.
command BumpAccountBalance(id: uuid, balance: int, expectedVersion: int, newVersion: int) =
  update Account filter .id = id and .version = expectedVersion
  set { balance := balance, version := newVersion };

command DeleteWidget(id: uuid) =
  delete Widget filter .id = id;

# Full-entity query: returns Widget with all mapped columns (FR-006).
query WidgetsByMinQuantity(min: int) =
  select Widget
  filter .quantity >= min
  order by .quantity desc;

# Flat projection: a distinct type exposing exactly id + name (FR-007/FR-008).
query WidgetNames(min: int) =
  select Widget { id, name }
  filter .quantity >= min
  order by .name asc;

# Optional parameters (FR-012/FR-031): each filter is included only when its parameter is supplied;
# the result type is the same for every combination.
query SearchWidgets(minQuantity: optional int, name: optional str) =
  select Widget
  filter .quantity >= minQuantity and .name = name
  order by .name asc;
