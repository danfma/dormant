module catalog;

# Authored write mutations → INSERT … RETURNING, materialize the inserted row.
mutation create_widget(id: uuid, name: string, quantity: int) {
  insert Widget w {
    w.id = id
    w.name = name
    w.quantity = quantity
  }
}

# 003 with-block (FR-021/FR-022): bind an inserted Author, then insert an Article whose `writer` FK flows
# from the bound author id; each binding is its own statement in the transaction. Returns the article id.
mutation create_author_with_article(aid: uuid, aname: string, artid: uuid, title: string) {
  with a = (insert Author x {
    x.id = aid
    x.name = aname
  })
  insert Article r {
    r.id = artid
    r.title = title
    r.writer = a
  }
  returning r.id
}

mutation create_account(id: uuid, balance: int, version: int) {
  insert Account a {
    a.id = id
    a.balance = balance
    a.version = version
  }
}

mutation create_stock_item(id: uuid, itemName: string) {
  insert StockItem s {
    s.id = id
    s.itemName = itemName
  }
}

mutation create_document(id: uuid, data: json) {
  insert Document d {
    d.id = id
    d.data = data
  }
}

# update with optimistic concurrency: matches the expected version; stale → 0 rows affected.
mutation bump_account_balance(id: uuid, balance: int, expectedVersion: int, newVersion: int) {
  update Account a
  where a.id == id && a.version == expectedVersion
  set {
    a.balance = balance
    a.version = newVersion
  }
}

mutation delete_widget(id: uuid) {
  delete Widget w
  where w.id == id
}

# Full-entity query: returns Widget with all mapped columns (FR-006).
query widgets_by_min_quantity(min: int) {
  from Widget w
  where w.quantity >= min
  order by w.quantity desc
  select w
}

# Flat projection: a distinct type exposing exactly id + name (FR-007/FR-008).
query widget_names(min: int) {
  from Widget w
  where w.quantity >= min
  order by w.name asc
  select {
    w.id
    w.name
  }
}

# Optional parameters (FR-012/FR-031): each filter is included only when its parameter is supplied;
# the result type is the same for every combination.
query search_widgets(minQuantity: optional int, name: optional string) {
  from Widget w
  where w.quantity >= minQuantity && w.name == name
  order by w.name asc
  select w
}
