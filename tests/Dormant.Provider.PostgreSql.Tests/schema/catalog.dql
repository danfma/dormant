module catalog;

# Full-entity query: returns Widget with all mapped columns (FR-006).
query WidgetsByMinQuantity(min: int) =
  select Widget
  filter .quantity >= min
  order by .quantity desc;

# Flat projection: a distinct type exposing exactly id + name (FR-007/FR-008).
query WidgetNames(min: int) =
  select Widget { id, name }
  filter .quantity >= min
  order by .name asc;

# Optional parameters (FR-012/FR-031): each filter is included only when its parameter is supplied;
# the result type is the same for every combination.
query SearchWidgets(minQuantity: optional int, name: optional str) =
  select Widget
  filter .quantity >= minQuantity and .name = name
  order by .name asc;
