module smoke;

mutation create_item(id: Uuid, name: String, quantity: Int, tags: Json, version: Int) {
  insert Item i {
    i.id = id
    i.name = name
    i.quantity = quantity
    i.tags = tags
    i.version = version
  }
}

query items_by_name(name: String) {
  from Item i
  where i.name == name
  order by i.name asc
  select i
}

query item_names(min: optional Int) {
  from Item i
  where i.quantity >= min
  select {
    i.id
    i.name
  }
}
