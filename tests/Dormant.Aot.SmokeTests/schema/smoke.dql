module smoke;

mutation create_item(id: uuid, name: string, quantity: int, tags: json, version: int) {
  insert Item i {
    i.id = id
    i.name = name
    i.quantity = quantity
    i.tags = tags
    i.version = version
  }
}

query items_by_name(name: string) {
  from Item i
  where i.name == name
  order by i.name asc
  select i
}

query item_names(min: optional int) {
  from Item i
  where i.quantity >= min
  select {
    i.id
    i.name
  }
}
