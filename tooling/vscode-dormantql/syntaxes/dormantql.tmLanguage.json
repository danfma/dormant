{
  "scopeName": "source.dormantql",
  "patterns": [
    { "include": "#comment" },
    { "include": "#keyword" },
    { "include": "#entity" },
    { "include": "#query" },
    { "include": "#mutation" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        { "match": "(#|//).*$", "name": "comment.line.double-slash.dormantql" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block.dormantql" }
      ]
    },
    "keyword": {
      "match": "\\b(module|entity|query|mutation|from|where|select|insert|update|delete|with|returning|set|order|by|optional|scalar|extending|abstract|constraint|annotation|on|as)\\b",
      "name": "keyword.control.dormantql"
    },
    "entity": {
      "begin": "\\bentity\\b",
      "end": "(?=\\bentity\\b|\\bquery\\b|\\bmutation\\b|$)",
      "patterns": [
        { "match": "\\bentity\\b", "name": "keyword.control.dormantql" },
        { "include": "#identifier" },
        { "include": "#type" }
      ]
    },
    "query": {
      "begin": "\\bquery\\b",
      "end": "(?=\\bentity\\b|\\bquery\\b|\\bmutation\\b|$)",
      "patterns": [
        { "match": "\\bquery\\b", "name": "keyword.control.dormantql" },
        { "include": "#identifier" },
        { "include": "#keyword" }
      ]
    },
    "mutation": {
      "begin": "\\bmutation\\b",
      "end": "(?=\\bentity\\b|\\bquery\\b|\\bmutation\\b|$)",
      "patterns": [
        { "match": "\\bmutation\\b", "name": "keyword.control.dormantql" },
        { "include": "#identifier" },
        { "include": "#keyword" }
      ]
    },
    "type": {
      "match": "\\b(String|Char|Byte|Short|Int|Long|Float|Double|Decimal|Bool|Uuid|DateTime|Date|Time|Json)\\b",
      "name": "storage.type.dormantql"
    },
    "string": {
      "match": "\"(\\\\.|[^\"\\\\])*\"",
      "name": "string.quoted.double.dormantql"
    },
    "number": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.dormantql"
    },
    "identifier": {
      "match": "[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.other.dormantql"
    }
  }
}